{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": ["/private/tmp", "~/go/src/github.com/DataDog/rshell"]
    },
    "network": {
      "allowedDomains": ["*.datadoghq.com", "*.github.com"]
    }
  },
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "Agent",
      "Skill",
      "WebFetch",
      "WebSearch",
      "LSP",
      "Bash(go *)",
      "Bash(gofmt *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(docker *)",
      "Bash(sleep *)",
      "Bash(tar *)",
      "Bash(RSHELL_BASH_TEST=1 go *)",
      "Bash(RSHELL_COMPLIANCE_TEST=1 go *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(sed *)"
    ]
  }
}
