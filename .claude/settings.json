{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "_excludedCommands_comment": "These commands need network access and must run outside the sandbox, but are explicitly allowed in the permissions list so they won't prompt.",
    "excludedCommands": ["git", "gh", "docker"],
    "filesystem": {
      "read": {
        "allow": ["~/go/pkg"]
      }
    },
    "network": {
      "allowedDomains": ["*.datadoghq.com", "*.github.com"]
    }
  },
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "Agent",
      "Skill",
      "WebFetch",
      "WebSearch",
      "LSP",
      "Bash(go *)",
      "Bash(gofmt *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(docker *)",
      "Bash(sleep *)",
      "Bash(tar *)",
      "Bash(RSHELL_BASH_TEST=1 go *)",
      "Bash(RSHELL_COMPLIANCE_TEST=1 go *)"
    ]
  }
}
